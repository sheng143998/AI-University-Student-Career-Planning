<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.itsheng.service.mapper.JobMapper">

    <!-- 结果映射 -->
    <resultMap id="JobResultMap" type="com.itsheng.pojo.entity.JobEntity">
        <id column="id" property="id"/>
        <result column="job_name" property="jobName"/>
        <result column="address" property="address"/>
        <result column="salary_range" property="salaryRange"/>
        <result column="company_name" property="companyName"/>
        <result column="industry" property="industry"/>
        <result column="company_size" property="companySize"/>
        <result column="company_type" property="companyType"/>
        <result column="job_code" property="jobCode"/>
        <result column="job_detail" property="jobDetail"/>
        <result column="update_date" property="updateDate"/>
        <result column="company_detail" property="companyDetail"/>
        <result column="source_url" property="sourceUrl"/>
        <result column="create_time" property="createTime" javaType="java.time.LocalDateTime"/>
        <result column="update_time" property="updateTime" javaType="java.time.LocalDateTime"/>
    </resultMap>

    <!-- 插入岗位数据 -->
    <insert id="insert" parameterType="com.itsheng.pojo.entity.JobEntity" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO ai_career_plan.recruitment_data (
            job_name,
            address,
            salary_range,
            company_name,
            industry,
            company_size,
            company_type,
            job_code,
            job_detail,
            update_date,
            company_detail,
            source_url,
            create_time,
            update_time
        ) VALUES (
            #{jobName},
            #{address},
            #{salaryRange},
            #{companyName},
            #{industry},
            #{companySize},
            #{companyType},
            #{jobCode},
            #{jobDetail},
            #{updateDate},
            #{companyDetail},
            #{sourceUrl},
            #{createTime},
            #{updateTime}
        )
    </insert>

    <!-- 批量插入岗位数据 -->
    <insert id="insertBatch" parameterType="java.util.List">
        INSERT INTO ai_career_plan.recruitment_data (
            job_name,
            address,
            salary_range,
            company_name,
            industry,
            company_size,
            company_type,
            job_code,
            job_detail,
            update_date,
            company_detail,
            source_url,
            create_time,
            update_time
        ) VALUES
        <foreach collection="jobs" item="job" separator=",">
            (
                #{job.jobName},
                #{job.address},
                #{job.salaryRange},
                #{job.companyName},
                #{job.industry},
                #{job.companySize},
                #{job.companyType},
                #{job.jobCode},
                #{job.jobDetail},
                #{job.updateDate},
                #{job.companyDetail},
                #{job.sourceUrl},
                #{job.createTime},
                #{job.updateTime}
            )
        </foreach>
    </insert>

    <!-- 根据 ID 查询岗位数据 -->
    <select id="selectById" resultMap="JobResultMap">
        SELECT *
        FROM ai_career_plan.recruitment_data
        WHERE id = #{id}
    </select>

    <!-- 查询所有岗位数据 -->
    <select id="selectAll" resultMap="JobResultMap">
        SELECT *
        FROM ai_career_plan.recruitment_data
        ORDER BY id DESC
    </select>

    <!-- 动态更新岗位数据 -->
    <update id="update" parameterType="com.itsheng.pojo.entity.JobEntity">
        UPDATE ai_career_plan.recruitment_data
        <set>
            <if test="jobName != null">job_name = #{jobName},</if>
            <if test="address != null">address = #{address},</if>
            <if test="salaryRange != null">salary_range = #{salaryRange},</if>
            <if test="companyName != null">company_name = #{companyName},</if>
            <if test="industry != null">industry = #{industry},</if>
            <if test="companySize != null">company_size = #{companySize},</if>
            <if test="companyType != null">company_type = #{companyType},</if>
            <if test="jobCode != null">job_code = #{jobCode},</if>
            <if test="jobDetail != null">job_detail = #{jobDetail},</if>
            <if test="updateDate != null">update_date = #{updateDate},</if>
            <if test="companyDetail != null">company_detail = #{companyDetail},</if>
            <if test="sourceUrl != null">source_url = #{sourceUrl},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </set>
        WHERE id = #{id}
    </update>

</mapper>
